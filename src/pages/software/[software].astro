---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import { SOFTWARE } from '../../consts';
import type { Software } from '../../consts';

export function getStaticPaths() {
  return (Object.keys(SOFTWARE) as Software[]).map((software) => ({
    params: { software },
  }));
}

const { software } = Astro.params as { software: Software };
const label = SOFTWARE[software];

const posts = (await getCollection('posts'))
  .filter((post) => post.data.software.includes(software))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Base title={label}>
  <h1>{label} の記事</h1>
  {posts.length === 0 && <p>まだ記事がありません。</p>}
  <ul class="post-list">
    {posts.map((post) => <PostCard post={post} />)}
  </ul>
</Base>

<style>
  h1 {
    font-size: 1.5rem;
  }
  .post-list {
    margin: 1.5rem 0 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
</style>
