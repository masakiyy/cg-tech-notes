---
import { SITE_TITLE } from '../consts';
const year = new Date().getFullYear();
---

<footer>
  <p>
    © {year} {SITE_TITLE} —
    記事は一次情報・コミュニティの知見を筆者が検証・再構成したものです。各記事末尾の出典を参照してください。
  </p>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 1.25rem 3rem;
    text-align: center;
    color: var(--text-dim);
    font-size: 0.8rem;
  }
</style>
